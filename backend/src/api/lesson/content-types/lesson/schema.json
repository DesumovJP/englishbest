{
  "kind": "collectionType",
  "collectionName": "lessons",
  "info": {
    "singularName": "lesson",
    "pluralName": "lessons",
    "displayName": "Lesson",
    "description": "Atomic learning unit inside a course."
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "title": {
      "type": "string",
      "required": true
    },
    "course": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::course.course",
      "inversedBy": "lessons"
    },
    "sectionSlug": {
      "type": "string"
    },
    "orderIndex": {
      "type": "integer",
      "default": 0
    },
    "type": {
      "type": "enumeration",
      "enum": ["video", "quiz", "reading", "interactive"],
      "default": "video",
      "required": true
    },
    "durationMin": {
      "type": "integer"
    },
    "video": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["videos"]
    },
    "videoUrl": {
      "type": "string"
    },
    "transcript": {
      "type": "text"
    },
    "cover": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "exercises": {
      "type": "component",
      "repeatable": true,
      "component": "lesson.exercise"
    },
    "steps": {
      "type": "json"
    },
    "xp": {
      "type": "integer",
      "default": 10
    },
    "isFree": {
      "type": "boolean",
      "default": false
    },
    "owner": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::teacher-profile.teacher-profile"
    },
    "source": {
      "type": "enumeration",
      "enum": ["platform", "own", "copy", "template"],
      "default": "platform",
      "required": true
    },
    "originalLesson": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::lesson.lesson"
    },
    "topic": {
      "type": "string"
    },
    "level": {
      "type": "enumeration",
      "enum": ["A0", "A1", "A2", "B1", "B2", "C1", "C2"]
    },
    "tags": {
      "type": "json"
    },
    "accentColor": {
      "type": "string",
      "regex": "^#[0-9a-fA-F]{6}$"
    }
  }
}
