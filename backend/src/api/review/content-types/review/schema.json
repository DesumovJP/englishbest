{
  "kind": "collectionType",
  "collectionName": "reviews",
  "info": {
    "singularName": "review",
    "pluralName": "reviews",
    "displayName": "Review",
    "description": "Student review on a course."
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "course": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::course.course"
    },
    "author": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::user-profile.user-profile"
    },
    "rating": {
      "type": "integer",
      "min": 1,
      "max": 5,
      "required": true
    },
    "title": {
      "type": "string"
    },
    "body": {
      "type": "text"
    },
    "verified": {
      "type": "boolean",
      "default": false
    }
  }
}
