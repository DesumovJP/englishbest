# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
coverage/

# next.js
.next/
out/

# production
build/
dist/

# strapi
.strapi/
.cache/
frontend/.next/
backend/.tmp/
backend/build/
backend/dist/
backend/public/uploads/*
!backend/public/uploads/.gitkeep
backend/database/migrations/*.sql
backend/exports/
backend/.strapi-updater.json

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.env.development.local
.env.test.local
.env.production.local
.env.local

# env files (can opt-in for committing if needed)
.env
.env.*
!.env.example

# vercel
.vercel

# storybook
storybook-static/

# typescript
*.tsbuildinfo
next-env.d.ts

# editor
.idea/
.vscode/
*.swp

# playwright
.playwright-mcp/

# claude code
.claude/

# screenshot debris (generated by UI audit sessions)
*.png
*.jpg
*.jpeg
!frontend/public/**/*.png
!frontend/public/**/*.jpg
!frontend/public/**/*.jpeg
